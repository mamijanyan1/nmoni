rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Zero-Trust Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Workspaces matching rule
    match /workspaces/{workspaceId} {
      // Allow operations if authenticated or if targeting the main shared workspace
      allow read, write: if request.auth != null || workspaceId == "smm_workspace_main";
    }
  }
}
